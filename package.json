{
  "name": "oura-health-alexa-skill",
  "version": "1.0.0",
  "description": "Alexa skill for Oura health data with smart home automation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-config.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "test-api": "ts-node scripts/test-api.ts",
    "setup-spotify": "ts-node scripts/setup-spotify-playlist.ts",
    "setup-sheets": "ts-node scripts/setup-google-sheets.ts",
    "backfill-sheets": "ts-node scripts/backfill-sheets.ts",
    "sync-sheets": "ts-node scripts/sync-sheets.ts",
    "export:oura": "ts-node src/scripts/export-oura.ts",
    "manage:oura-webhooks": "ts-node src/scripts/manage-oura-webhooks.ts",
    "package": "npm run build && serverless package",
    "deploy": "npm run build && serverless deploy",
    "deploy:prod": "npm run build && serverless deploy --stage prod",
    "remove": "serverless remove",
    "logs": "serverless logs -f alexa -t"
  },
  "keywords": [
    "oura",
    "alexa",
    "smart-home",
    "health"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1088.0",
    "@aws-sdk/client-sqs": "^3.1088.0",
    "ask-sdk": "^2.14.0",
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-express-adapter": "^2.14.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/spotify-web-api-node": "^5.0.11",
    "serverless": "^3.38.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
