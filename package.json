{
  "name": "oura-health-alexa-skill",
  "version": "1.0.0",
  "description": "Alexa skill for Oura health data with smart home automation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-config.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-api": "ts-node scripts/test-api.ts",
    "setup-spotify": "ts-node scripts/setup-spotify-playlist.ts",
    "setup:spotify-oauth": "ts-node src/scripts/setup-spotify-oauth.ts",
    "setup-sheets": "ts-node scripts/setup-google-sheets.ts",
    "backfill-sheets": "ts-node scripts/backfill-sheets.ts",
    "sync-sheets": "ts-node scripts/sync-sheets.ts",
    "export:oura": "ts-node src/scripts/export-oura.ts",
    "setup:oura-oauth": "ts-node src/scripts/setup-oura-oauth.ts",
    "manage:oura-webhooks": "ts-node src/scripts/manage-oura-webhooks.ts",
    "start:gcp:webhook": "GCP_SERVICE_MODE=webhook node dist/gcp/webhookServer.js",
    "start:gcp:worker": "GCP_SERVICE_MODE=worker node dist/gcp/workerServer.js",
    "deploy:gcp": "npm run build && bash scripts/deploy-gcp.sh"
  },
  "keywords": [
    "oura",
    "alexa",
    "smart-home",
    "health"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/secret-manager": "^6.2.0",
    "@google-cloud/tasks": "^6.2.3",
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-express-adapter": "^2.14.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/spotify-web-api-node": "^5.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vitest": "^1.6.1"
  }
}
