# Oura
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:9877/callback

# Govee (optional)
GOVEE_API_KEY=

# Google Sheets export
# Either point at a service account JSON key file...
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json
# ...or paste the raw JSON (takes precedence; useful for serverless deployments).
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Server
PORT=3000

# Google Cloud production deployment
GCP_PROJECT_ID=
GCP_REGION=us-east1
GCP_FIRESTORE_LOCATION=us-east1
# Keep false until any legacy AWS schedules are disabled, then set true and deploy.
GCP_ENABLE_AUTOMATION_CUTOVER=false
